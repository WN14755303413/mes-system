// MES 系统数据模型
// schema 由 DATABASE_URL 中的 ?schema=mes 指定，与 Supabase 自身的 auth/storage 表隔离。
//
// 本文件当前只含【系统域】。业务域（项目、BOM、工单、质量…）随各里程碑增量添加。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Transaction Pooler，运行时用
  directUrl = env("DIRECT_URL") // 直连，migrate 用（迁移不能走 pooler）
}

// ============================================================
//  组织与账号
// ============================================================

/// 部门。自引用树，`path` 存祖先链（如 /root/rd/mech/），用于 DEPT_AND_BELOW 数据权限的前缀匹配。
model Dept {
  id       String  @id @default(cuid())
  name     String
  code     String  @unique
  parentId String? @map("parent_id")
  path     String  @default("/")
  sort     Int     @default(0)
  enabled  Boolean @default(true)

  parent   Dept?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Dept[] @relation("DeptTree")
  users    User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([path])
  @@map("sys_dept")
}

model User {
  id          String @id @default(cuid())
  username    String @unique
  displayName String @map("display_name")

  /// Argon2id 哈希。系统中任何位置都不保存明文密码，本字段无法反推出原密码。
  passwordHash String @map("password_hash")

  email  String? @unique
  phone  String?
  status String  @default("ACTIVE") // UserStatus

  /// 为 true 时，除「修改密码」外的所有接口返回 403 PASSWORD_CHANGE_REQUIRED。
  /// 初始管理员 seed 后即为 true，强制首次登录改密。
  mustChangePassword Boolean @default(false) @map("must_change_password")

  /// 密码最后修改时间，用于「密码过期」策略与 token 失效判定。
  passwordChangedAt DateTime @default(now()) @map("password_changed_at")

  /// 账号锁定截止时间。连续登录失败达阈值后设置。
  lockedUntil DateTime? @map("locked_until")

  /// 连续失败次数，登录成功后清零。
  failedLoginCount Int @default(0) @map("failed_login_count")

  lastLoginAt DateTime? @map("last_login_at")
  lastLoginIp String?   @map("last_login_ip")

  /// 钉钉集成预留（建设方案 §11.1）。组织同步后，离职人员自动置为 DISABLED。
  dingtalkUserId String? @unique @map("dingtalk_userid")

  deptId String? @map("dept_id")
  dept   Dept?   @relation(fields: [deptId], references: [id], onDelete: SetNull)

  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  // 项目域反向关系（M4）
  managedProjects Project[]       @relation("ProjectManager")
  ownedTasks      ProjectTask[]   @relation("TaskOwner")
  ownedRisks      ProjectRisk[]   @relation("RiskOwner")
  ownedIssues     ProjectIssue[]  @relation("IssueOwner")
  projectMembers  ProjectMember[] @relation("ProjectMembership")

  // BOM 与图纸域反向关系（M5）
  createdBoms      Bom[]     @relation("BomCreator")
  releasedBoms     Bom[]     @relation("BomReleaser")
  uploadedDrawings Drawing[] @relation("DrawingUploader")

  // 物料与齐套域反向关系（M6）
  requestedRequisitions Requisition[] @relation("RequisitionRequester")
  confirmedRequisitions Requisition[] @relation("RequisitionConfirmer")

  // 生产执行域反向关系（M7）
  createdWorkOrders  WorkOrder[]     @relation("WorkOrderCreator")
  assignedTasks      AssemblyTask[]  @relation("AssemblyTaskAssignee")
  workReports        WorkReport[]    @relation("WorkReporter")
  reportedExceptions WorkException[] @relation("ExceptionReporter")
  handledExceptions  WorkException[] @relation("ExceptionHandler")
  closedExceptions   WorkException[] @relation("ExceptionCloser")
  uploadedFiles      Attachment[]    @relation("AttachmentUploader")

  // 质量管理域反向关系（M8）
  inspections           Inspection[]         @relation("InspectionInspector")
  judgedInspections     Inspection[]         @relation("InspectionJudge")
  reportedQualityIssues QualityIssue[]       @relation("QualityIssueReporter")
  handledQualityIssues  QualityIssue[]       @relation("QualityIssueHandler")
  closedQualityIssues   QualityIssue[]       @relation("QualityIssueCloser")
  qualityIssueActions   QualityIssueAction[] @relation("QualityIssueOperator")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deptId])
  @@index([status])
  @@map("sys_user")
}

// ============================================================
//  RBAC
// ============================================================

model Role {
  id        String  @id @default(cuid())
  code      String  @unique // BuiltinRole 或自定义
  name      String
  remark    String?
  /// 该角色的数据可见范围（DataScope）。用户有多角色时取最宽松的一个。
  dataScope String  @default("SELF_ONLY") @map("data_scope")
  /// 内置角色不可删除
  builtin   Boolean @default(false)
  enabled   Boolean @default(true)

  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sys_role")
}

model Permission {
  id     String           @id @default(cuid())
  /// 形如 `project:create`，与 packages/shared/src/permissions.ts 保持一致
  code   String           @unique
  name   String
  module String
  roles  RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([module])
  @@map("sys_permission")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("sys_user_role")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("sys_role_permission")
}

// ============================================================
//  会话与登录防护
// ============================================================

/// Refresh token 只存哈希值。即使数据库泄露，也无法还原出可用的 token。
/// 采用轮换（rotation）策略：每次刷新签发新 token 并作废旧的。
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  /// 同一登录会话的所有 token 共享一个 family id。
  /// 检测到已撤销 token 被复用 → 判定为窃取 → 吊销整个 family。
  familyId  String    @map("family_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("sys_refresh_token")
}

/// 忘记密码申请。
///
/// 本系统没有邮件服务，也刻意不做「邮件重置链接」——内部系统的账号绑定的是工号而非邮箱，
/// 且邮件链接会新增一条可被钓鱼利用的攻击路径。改为人工核实：员工提交申请，
/// 系统管理员在后台核对姓名/手机号后重置密码并下发临时密码（mustChangePassword=true）。
///
/// 刻意不存 userId：申请提交时不校验账号是否存在（防用户名枚举），
/// 因此这里只保存用户填写的原始信息，由管理员在处理时人工匹配。
model PasswordResetRequest {
  id          String  @id @default(cuid())
  username    String
  displayName String  @map("display_name")
  phone       String
  reason      String?

  /// PENDING / APPROVED / REJECTED
  status String @default("PENDING")

  ip        String?
  userAgent String? @map("user_agent")

  /// 处理人（管理员）的用户 id 与处理备注
  handledBy  String?   @map("handled_by")
  handledAt  DateTime? @map("handled_at")
  handleNote String?   @map("handle_note")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([username])
  @@map("sys_password_reset_request")
}

/// 登录尝试记录。用于 IP 维度与账号维度的双重限流。
model LoginAttempt {
  id        String  @id @default(cuid())
  username  String
  ip        String
  success   Boolean
  reason    String?
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([username, createdAt])
  @@index([ip, createdAt])
  @@map("sys_login_attempt")
}

// ============================================================
//  审计与集成日志
// ============================================================

/// 操作审计（建设方案 §13）。图纸/BOM 的下载与预览单独记录。
model AuditLog {
  id         String  @id @default(cuid())
  userId     String? @map("user_id")
  username   String? // 冗余保存，用户删除后仍可追溯
  action     String // 如 project.create / drawing.download
  targetType String? @map("target_type")
  targetId   String? @map("target_id")
  /// 变更前后的 diff，仅记录发生变化的字段
  changes    Json?
  ip         String?
  userAgent  String? @map("user_agent")
  success    Boolean @default(true)
  errorMsg   String? @map("error_msg")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("sys_audit_log")
}

/// 接口日志（建设方案 §11.3）。失败的记录构成「异常池」，支持重试与人工补偿。
model IntegrationLog {
  id              String    @id @default(cuid())
  interfaceName   String    @map("interface_name")
  sourceSystem    String    @map("source_system") // ERP / DINGTALK / ANT / MES
  targetSystem    String    @map("target_system")
  requestSummary  Json?     @map("request_summary")
  responseSummary Json?     @map("response_summary")
  success         Boolean
  errorMsg        String?   @map("error_msg")
  retryCount      Int       @default(0) @map("retry_count")
  /// 待人工补偿的记录标记为 true
  needsAttention  Boolean   @default(false) @map("needs_attention")
  resolvedAt      DateTime? @map("resolved_at")
  triggeredBy     String?   @map("triggered_by") // 操作人 id 或 "SCHEDULER"

  createdAt DateTime @default(now()) @map("created_at")

  @@index([interfaceName, createdAt])
  @@index([success, needsAttention])
  @@map("sys_integration_log")
}

// ============================================================
//  编号序列（建设方案 §10.2）
// ============================================================

/// 单据流水号。用唯一约束 + 原子自增保证并发下不重号。
/// scope 形如 "PJ-2026-ABC" 或 "QC-20260709"
model CodeSequence {
  id      String @id @default(cuid())
  scope   String @unique
  current Int    @default(0)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sys_code_sequence")
}

// ============================================================
//  项目域（M4）
//
//  项目是整个 MES 的主线对象，后续里程碑的 BOM、齐套、工单、质量、
//  调试都挂到 project 上。客户/合同/物料属于 ERP 同步的主数据（后续里程碑
//  才建表），本阶段项目上先以文本字段保存客户名与合同号快照，待主数据域
//  就绪后再补外键关联。
// ============================================================

/// 项目台账。编号形如 PJ-2026-ABC-001，由 CodeGeneratorService 生成。
/// status 走通用状态机（RecordStatus）：草稿→已发布→执行中→…→已关闭。
model Project {
  id   String @id @default(cuid())
  code String @unique // PJ-2026-ABC-001
  name String

  /// 客户名快照。ERP 客户主数据接入后改为 customerId 外键。
  customerName String? @map("customer_name")
  /// 合同/销售订单号快照。同上，ERP 合同域就绪后关联。
  contractNo   String? @map("contract_no")

  /// 项目类型：单片湿法 / 槽式 / 电镀化镀 / 定制 等，一期自由文本。
  projectType String? @map("project_type")

  /// 通用状态机状态（RecordStatus）。默认草稿。
  status String @default("DRAFT")

  /// 风险等级：LOW / MEDIUM / HIGH / CRITICAL。由项目风险汇总或人工设定。
  riskLevel String @default("LOW") @map("risk_level")

  /// 设备数量。一个项目可对应一台或多台设备（建设方案 §4.1）。
  equipmentCount Int @default(1) @map("equipment_count")

  /// 项目经理（sys_user）。离职置空而非级联删项目。
  managerId String? @map("manager_id")
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  planStartAt DateTime? @map("plan_start_at")
  planEndAt   DateTime? @map("plan_end_at") // 计划交期
  actualEndAt DateTime? @map("actual_end_at") // 实际交期

  description String?

  milestones ProjectMilestone[]
  tasks      ProjectTask[]
  risks      ProjectRisk[]
  issues     ProjectIssue[]
  members    ProjectMember[]
  boms       Bom[]
  drawings   Drawing[]

  // 物料与齐套域反向关系（M6）
  poItems      PurchaseOrderItem[] @relation("PoItemProject")
  arrivals     Arrival[]           @relation("ArrivalProject")
  stocks       Stock[]             @relation("StockProject")
  requisitions Requisition[]       @relation("RequisitionProject")

  // 生产执行域反向关系（M7）
  workOrders     WorkOrder[]     @relation("WorkOrderProject")
  prodExceptions WorkException[] @relation("ExceptionProject")

  // 质量管理域反向关系（M8）
  inspections   Inspection[]   @relation("InspectionProject")
  qualityIssues QualityIssue[] @relation("QualityIssueProject")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([managerId])
  @@map("project")
}

/// 项目里程碑（关键节点）。用于台账详情的时间轴与延期判定。
model ProjectMilestone {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name       String
  planDate   DateTime? @map("plan_date")
  /// 实际达成日期；非空即视为已完成。
  actualDate DateTime? @map("actual_date")
  sort       Int       @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("project_milestone")
}

/// WBS 任务。自引用树，是甘特图的数据源。
/// path 存祖先链（如 /rootTaskId/parentId/），与 Dept 同构，便于取整棵子树。
model ProjectTask {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentId String?       @map("parent_id")
  parent   ProjectTask?  @relation("TaskTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectTask[] @relation("TaskTree")
  path     String        @default("/")

  name    String
  /// 任务负责人（sys_user）。
  ownerId String? @map("owner_id")
  owner   User?   @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  planStartAt DateTime? @map("plan_start_at")
  planEndAt   DateTime? @map("plan_end_at")

  /// 完成百分比 0-100，甘特图进度条用。
  progress Int    @default(0)
  /// 任务状态（RecordStatus 子集，一期用 DRAFT/IN_PROGRESS/COMPLETED）。
  status   String @default("DRAFT")

  sort Int @default(0)

  /// 关联到本 WBS 节点的装配工单（M7）。工单报工进度回写本节点。
  workOrders WorkOrder[] @relation("WorkOrderWbsTask")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([parentId])
  @@index([path])
  @@map("project_task")
}

/// 项目风险登记（建设方案 §8.1）。
model ProjectRisk {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title      String
  /// 风险等级：LOW / MEDIUM / HIGH / CRITICAL。
  level      String  @default("MEDIUM")
  /// 应对措施。
  mitigation String?
  /// OPEN / CLOSED。关闭即视为已消除或已转化为问题。
  status     String  @default("OPEN")

  ownerId String? @map("owner_id")
  owner   User?   @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("project_risk")
}

/// 项目问题闭环（建设方案 §8.1）。区别于质量问题单（M7），这是项目层面的协调问题。
model ProjectIssue {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String?
  /// OPEN / IN_PROGRESS / RESOLVED / CLOSED。
  status      String  @default("OPEN")
  /// 优先级：LOW / MEDIUM / HIGH。
  priority    String  @default("MEDIUM")

  ownerId String? @map("owner_id")
  owner   User?   @relation("IssueOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  dueDate    DateTime? @map("due_date")
  resolvedAt DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("project_issue")
}

/// 项目成员及其项目内角色。用于 OWNED_PROJECT 数据范围判定与协同人展示。
model ProjectMember {
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("ProjectMembership", fields: [userId], references: [id], onDelete: Cascade)

  /// 项目内角色描述（如 机械设计 / 电气调试），自由文本，与全局 RBAC 角色无关。
  roleInProject String? @map("role_in_project")

  createdAt DateTime @default(now()) @map("created_at")

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_member")
}

// ============================================================
//  BOM 与图纸域（M5）
//
//  BOM 一行一个版本，走独立的 BomStatus 状态机（草稿→已发布→冻结/变更中→作废），
//  与通用 RecordStatus 分离——BOM 有「冻结」语义而无执行过程语义。
//  ECO 采用轻量版本链：新版本从 sourceBomId 派生并记录变更原因，
//  新版发布时旧版自动作废，防止现场误用旧版（业务方案 §8.2）。
// ============================================================

/// 项目 BOM 版本。version 形如 V1.0（编码规则 §10.2），同项目内唯一。
model Bom {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  version String
  /// BomStatus。现场（无 bom:write）只能看到 RELEASED / FROZEN。
  status  String  @default("DRAFT")
  remark  String?

  /// ECO 变更原因。从旧版本派生时必填（业务方案 §8.2「变更必须记录原因」）。
  changeReason String? @map("change_reason")
  /// 派生自哪个版本。初始版本为 null。删除旧版不级联新版，置空保历史。
  sourceBomId  String? @map("source_bom_id")
  source       Bom?    @relation("BomEcoChain", fields: [sourceBomId], references: [id], onDelete: SetNull)
  derived      Bom[]   @relation("BomEcoChain")

  releasedAt   DateTime? @map("released_at")
  releasedById String?   @map("released_by_id")
  releasedBy   User?     @relation("BomReleaser", fields: [releasedById], references: [id], onDelete: SetNull)

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("BomCreator", fields: [createdById], references: [id], onDelete: SetNull)

  items BomItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, version])
  @@index([projectId, status])
  @@map("bom")
}

/// BOM 明细行。仅草稿状态可编辑；发布后随版本一起只读。
model BomItem {
  id    String @id @default(cuid())
  bomId String @map("bom_id")
  bom   Bom    @relation(fields: [bomId], references: [id], onDelete: Cascade)

  /// 行号，展示排序用。批量导入时自动续排，不加唯一约束以免重排受阻。
  seq          Int
  materialCode String  @map("material_code")
  materialName String  @map("material_name")
  spec         String?
  unit         String  @default("件")
  /// 需求数量。Decimal 避免 0.1+0.2 类浮点误差进入齐套计算（M6 消费本字段）。
  quantity     Decimal @default(1) @db.Decimal(12, 3)
  /// 标准件 / 非标件（业务方案 §8.2）。
  isStandard   Boolean @default(true) @map("is_standard")
  remark       String?

  /// 关联图纸（可选）。图纸删除不连带删明细。
  drawingId String?  @map("drawing_id")
  drawing   Drawing? @relation(fields: [drawingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([bomId])
  @@map("bom_item")
}

// ============================================================
//  物料与齐套域（M6）
//
//  一期 ERP 接口未开通（业务方案 §21 兜底策略）：采购/到货/库存数据由
//  Excel 导入或手工维护进入，每张表带 syncSource/syncedAt 标注来源与时点，
//  导入动作写 sys_integration_log。将来接 ERP 只换数据入口，不动齐套逻辑。
//  齐套结果实时计算不落表；库存账务主权在 ERP，MES 只存快照不记增减账。
// ============================================================

/// 物料主数据（ERP 主数据的本地落地表）。主数据以 ERP 为准，
/// isLongLead/leadTimeDays 是 MES 侧执行扩展字段（齐套预警用）。
/// BomItem 仍存 materialCode 文本快照，齐套按编码关联；未建档的编码在看板上提示补录。
model Material {
  id   String  @id @default(cuid())
  code String  @unique // 物料编码，对齐 ERP 规则
  name String
  spec String?
  unit String  @default("件")

  /// 类别：机械件/电气件/管路件 等，一期自由文本。
  category   String?
  isStandard Boolean @default(true) @map("is_standard")

  /// 长周期物料标记与采购周期天数。缺口且无在途时高亮预警（业务方案 §8.3）。
  isLongLead   Boolean @default(false) @map("is_long_lead")
  leadTimeDays Int?    @map("lead_time_days")

  /// 数据来源：ERP / IMPORT / MANUAL（SyncSource）。
  syncSource String   @default("MANUAL") @map("sync_source")
  syncedAt   DateTime @default(now()) @map("synced_at")

  enabled Boolean @default(true)
  remark  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([enabled])
  @@index([isLongLead])
  @@map("mat_material")
}

/// 采购订单（ERP 镜像，MES 只读 + 备注扩展）。
model PurchaseOrder {
  id      String @id @default(cuid())
  orderNo String @unique @map("order_no")

  /// 供应商名快照。ERP 供应商主数据接入后改外键。
  supplierName String?   @map("supplier_name")
  orderDate    DateTime? @map("order_date")

  /// PoStatus：OPEN 执行中 / CLOSED 已完结 / CANCELLED 已取消。
  status String @default("OPEN")

  syncSource String   @default("IMPORT") @map("sync_source")
  syncedAt   DateTime @default(now()) @map("synced_at")
  remark     String?

  items PurchaseOrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("supply_purchase_order")
}

/// 采购订单明细。projectId 空 = 通用采购；riskNote 是采购员在 MES 侧
/// 唯一可写字段（交期风险说明，业务方案 §7.6）。
model PurchaseOrderItem {
  id      String        @id @default(cuid())
  orderId String        @map("order_id")
  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  materialCode    String  @map("material_code")
  materialName    String? @map("material_name")
  quantity        Decimal @db.Decimal(12, 3)
  /// 到货记录写入时累加。在途 = quantity - arrivedQuantity。
  arrivedQuantity Decimal @default(0) @map("arrived_quantity") @db.Decimal(12, 3)

  /// 预计到货日期。齐套看板据此给出「在途覆盖」行的最晚到货时间。
  expectedDate DateTime? @map("expected_date")

  /// 项目专项采购；空为通用采购。项目删除不连带删采购镜像。
  projectId String?  @map("project_id")
  project   Project? @relation("PoItemProject", fields: [projectId], references: [id], onDelete: SetNull)

  /// 采购员维护的交期风险备注。
  riskNote String? @map("risk_note")

  arrivals Arrival[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([materialCode])
  @@index([projectId])
  @@map("supply_purchase_order_item")
}

/// 到货/入库记录。poItemId 可空（允许无单到货）。
model Arrival {
  id String @id @default(cuid())

  poItemId String?            @map("po_item_id")
  poItem   PurchaseOrderItem? @relation(fields: [poItemId], references: [id], onDelete: SetNull)

  materialCode String  @map("material_code")
  quantity     Decimal @db.Decimal(12, 3)

  /// ArrivalType：ARRIVED 到货未入库（计入齐套的「已到货未领」）/ INBOUND 已入库（计入库存，不再重复计）。
  type String @default("ARRIVED")

  arrivedAt DateTime @map("arrived_at")

  projectId String?  @map("project_id")
  project   Project? @relation("ArrivalProject", fields: [projectId], references: [id], onDelete: SetNull)

  syncSource String   @default("IMPORT") @map("sync_source")
  syncedAt   DateTime @default(now()) @map("synced_at")
  remark     String?

  inspections Inspection[] @relation("InspectionArrival")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([materialCode])
  @@index([projectId])
  @@index([type])
  @@map("supply_arrival")
}

/// 库存快照。projectId 空 = 通用库存。每次导入整体覆盖（账务主权在 ERP，
/// MES 不做增减账），syncedAt 即看板上的「数据同步时间」。
model Stock {
  id String @id @default(cuid())

  materialCode      String   @map("material_code")
  projectId         String?  @map("project_id")
  project           Project? @relation("StockProject", fields: [projectId], references: [id], onDelete: Cascade)
  quantity          Decimal  @db.Decimal(12, 3)
  availableQuantity Decimal  @map("available_quantity") @db.Decimal(12, 3)

  syncSource String   @default("IMPORT") @map("sync_source")
  syncedAt   DateTime @default(now()) @map("synced_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([materialCode, projectId])
  @@index([projectId])
  @@map("supply_stock")
}

/// 领料/退料记录——MES 侧产生的数据（业务方案 §5.1）。
/// 仓库确认（CONFIRMED）后才计入齐套的「已领料」。
model Requisition {
  id   String @id @default(cuid())
  code String @unique // REQ-YYYYMMDD-XXX，CodeGeneratorService 生成

  projectId String  @map("project_id")
  project   Project @relation("RequisitionProject", fields: [projectId], references: [id], onDelete: Cascade)

  materialCode String  @map("material_code")
  quantity     Decimal @db.Decimal(12, 3)

  /// RequisitionType：ISSUE 领料 / RETURN 退料。
  type String @default("ISSUE")

  /// RequisitionStatus：DRAFT 待确认 / CONFIRMED 已确认 / CANCELLED 已取消。
  status String @default("DRAFT")

  requestedById String?   @map("requested_by_id")
  requestedBy   User?     @relation("RequisitionRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  confirmedById String?   @map("confirmed_by_id")
  confirmedBy   User?     @relation("RequisitionConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  confirmedAt   DateTime? @map("confirmed_at")

  remark String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId, status])
  @@index([materialCode])
  @@map("supply_requisition")
}

/// 图纸。版本号沿用设计端（业务方案 §10.2），MES 记录状态与有效性。
/// 文件本体在对象存储（storageKey），下载/预览必须经后端鉴权并留审计。
model Drawing {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 图号。同项目同图号上传新版本时，旧版自动置为 VOIDED。
  code    String
  name    String
  version String
  /// DrawingStatus：ACTIVE 有效 / VOIDED 已作废。现场（无 drawing:write）只见 ACTIVE。
  status  String @default("ACTIVE")

  /// 对象存储 key，驱动无关：local 驱动是根目录内相对路径，supabase 驱动是 bucket 内路径。
  storageKey String @map("storage_key")
  fileName   String @map("file_name")
  fileSize   Int    @map("file_size")
  mimeType   String @map("mime_type")

  uploadedById String? @map("uploaded_by_id")
  uploadedBy   User?   @relation("DrawingUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  voidedAt DateTime? @map("voided_at")
  remark   String?

  bomItems BomItem[]
  /// 关联本图纸的装配任务（M7）。装配工在「我的任务」里按图作业。
  assemblyTasks AssemblyTask[] @relation("AssemblyTaskDrawing")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, code, version])
  @@index([projectId, status])
  @@map("drawing")
}

// ============================================================
//  生产执行域（M7）
//
//  一期不建独立「生产计划」实体（业务方案 §8.4：不做复杂 APS）——
//  装配工单即计划单元：按设备/专业开单，带计划与实际日期；任务即工序计划，
//  派工到人。任务状态只由报工动作驱动（shared REPORT_ACTION_RULES），
//  报工在同一事务里累加工时、重算任务与工单进度，并回写关联的 WBS 任务，
//  这样 M4 甘特图与项目台账即时反映现场进度（M7 验收「报工回写项目进度」）。
// ============================================================

/// 装配工单。编号 WO-YYYYMMDD-XXX；status 走通用 RecordStatus 状态机
/// （草稿→已发布(下达)→执行中→…）。progress 由任务按标准工时加权汇总。
model WorkOrder {
  id   String @id @default(cuid())
  code String @unique

  projectId String  @map("project_id")
  project   Project @relation("WorkOrderProject", fields: [projectId], references: [id], onDelete: Cascade)

  name String
  /// 装配专业（CraftType）：机械/电气/管路/其它。仅草稿态可改。
  craft String @default("MECH")

  status String @default("DRAFT")

  planStartAt   DateTime? @map("plan_start_at")
  planEndAt     DateTime? @map("plan_end_at")
  /// 首次报工自动写入；完工确认时写 actualEndAt。
  actualStartAt DateTime? @map("actual_start_at")
  actualEndAt   DateTime? @map("actual_end_at")

  /// 0-100。报工事务内按任务标准工时加权重算，不由前端提交。
  progress Int @default(0)

  /// 关联的项目 WBS 任务；工单进度变化时回写其 progress/status（甘特图联动）。
  wbsTaskId String?      @map("wbs_task_id")
  wbsTask   ProjectTask? @relation("WorkOrderWbsTask", fields: [wbsTaskId], references: [id], onDelete: SetNull)

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("WorkOrderCreator", fields: [createdById], references: [id], onDelete: SetNull)

  remark String?

  tasks      AssemblyTask[]
  exceptions WorkException[]
  inspections   Inspection[]   @relation("InspectionWorkOrder")
  qualityIssues QualityIssue[] @relation("QualityIssueWorkOrder")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId, status])
  @@index([status])
  @@map("prod_work_order")
}

/// 装配任务（工序级派工单元）。装配工只能看到 assigneeId 为本人、
/// 且所属工单已下达的任务——行级过滤在 my-tasks 接口内强制。
model AssemblyTask {
  id          String    @id @default(cuid())
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  /// 工单内行号，展示排序用，新增自动续排。
  seq  Int
  name String

  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("AssemblyTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  /// AssemblyTaskStatus。只由报工动作驱动（REPORT_ACTION_RULES）。
  status String @default("PENDING")

  planStartAt   DateTime? @map("plan_start_at")
  planEndAt     DateTime? @map("plan_end_at")
  actualStartAt DateTime? @map("actual_start_at")
  actualEndAt   DateTime? @map("actual_end_at")

  /// 标准工时（小时）。既是工单进度加权权重，也是工时分析基准。
  standardHours Decimal? @map("standard_hours") @db.Decimal(7, 1)
  /// 累计实际工时（小时），报工累加。Decimal 防浮点累加误差。
  actualHours   Decimal  @default(0) @map("actual_hours") @db.Decimal(8, 1)

  progress Int @default(0)

  /// 作业图纸。现场从任务直达图纸预览（走 M5 下载接口，留审计）。
  drawingId String?  @map("drawing_id")
  drawing   Drawing? @relation("AssemblyTaskDrawing", fields: [drawingId], references: [id], onDelete: SetNull)

  /// 作业要求/指导说明。一期为文本；完整作业指导书属后续工艺模块。
  requirement String?
  remark      String?

  reports    WorkReport[]
  exceptions WorkException[]
  inspections   Inspection[]   @relation("InspectionTask")
  qualityIssues QualityIssue[] @relation("QualityIssueTask")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workOrderId])
  @@index([assigneeId, status])
  @@map("prod_task")
}

/// 报工记录（一次动作）。现场真实执行数据（业务方案 §5.1「只在 MES 中产生」），
/// 只增不改不删——写错就再报一笔修正，保留完整轨迹。
model WorkReport {
  id     String       @id @default(cuid())
  taskId String       @map("task_id")
  task   AssemblyTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// WorkReportType：START/PROGRESS/PAUSE/RESUME/COMPLETE/REWORK。
  type String

  /// 本次投入工时（小时）。
  hours Decimal @default(0) @db.Decimal(6, 1)

  /// 本次报工后的任务进度快照。
  progress Int

  note String?

  reporterId String? @map("reporter_id")
  reporter   User?   @relation("WorkReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([taskId, createdAt])
  @@index([reporterId, createdAt])
  @@map("prod_work_report")
}

/// 现场异常单（业务方案 §9.6）。编号 EX-YYYYMMDD-XXX。
/// 流转：OPEN →（指派）HANDLING →（责任人处理）RESOLVED →（确认）CLOSED，
/// 复检不通过可退回 HANDLING。区别于 M8 质量问题单：这是装配现场的执行异常。
model WorkException {
  id   String @id @default(cuid())
  code String @unique

  projectId String  @map("project_id")
  project   Project @relation("ExceptionProject", fields: [projectId], references: [id], onDelete: Cascade)

  /// 关联工单/任务可选（也允许与具体任务无关的现场异常）。删除工单不删异常记录。
  workOrderId String?    @map("work_order_id")
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)

  taskId String?       @map("task_id")
  task   AssemblyTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  /// 涉及物料编码（可选），供后续质量追溯反查。
  materialCode String? @map("material_code")

  title       String
  description String?

  /// ExceptionStatus。
  status String @default("OPEN")

  reporterId String? @map("reporter_id")
  reporter   User?   @relation("ExceptionReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  /// 责任人。指派后进入 HANDLING。
  handlerId String? @map("handler_id")
  handler   User?   @relation("ExceptionHandler", fields: [handlerId], references: [id], onDelete: SetNull)

  /// 处理说明（责任人填写；关闭/退回意见追加于此）。
  handleNote String?   @map("handle_note")
  resolvedAt DateTime? @map("resolved_at")

  closedById String?   @map("closed_by_id")
  closedBy   User?     @relation("ExceptionCloser", fields: [closedById], references: [id], onDelete: SetNull)
  closedAt   DateTime? @map("closed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId, status])
  @@index([handlerId, status])
  @@index([reporterId])
  @@map("prod_exception")
}

/// 通用附件索引（M7 起）。文件本体在对象存储，与图纸同一套 StorageService；
/// 按 targetType+targetId 挂到业务对象上。M7 用于异常单现场照片，
/// M8 检验单、M9 调试记录可直接复用，不再各建附件表。
model Attachment {
  id String @id @default(cuid())

  /// 业务对象类型：EXCEPTION（M7）/ INSPECTION、DEBUG…（后续里程碑）。
  targetType String @map("target_type")
  targetId   String @map("target_id")

  storageKey String @map("storage_key")
  fileName   String @map("file_name")
  fileSize   Int    @map("file_size")
  mimeType   String @map("mime_type")

  uploadedById String? @map("uploaded_by_id")
  uploadedBy   User?   @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@map("sys_attachment")
}

// ============================================================
//  质量管理域（M8，业务方案 §8.7 / §9.7）
// ============================================================

/// 检验单（M8）。编号 QC-YYYYMMDD-XXX（§10.2 的示例前缀）。
/// 生命周期：PENDING 待检（单头明细可编辑）→ judge → PASSED/REJECTED 终态（锁定），
/// PENDING 可作废。复检不新开检验单——复检是质量问题单上的动作（§9.7）。
/// 关联维度按类型必填（shared INSPECTION_TYPE_META，前后端同表）：
/// IQC→物料，IPQC/ASSY→工单（项目反查），FQC/DEBUG→项目。
/// 一期无设备实体（M9 一机一档），FQC 用 batchNo/备注记设备号，届时补可空外键。
model Inspection {
  id   String @id @default(cuid())
  code String @unique

  /// InspectionType：IQC/IPQC/ASSY/FQC/DEBUG。
  type String

  /// InspectionStatus。判定即终态，不走通用状态机。
  status String @default("PENDING")

  /// IQC 检通用物料时可无项目。
  projectId String?  @map("project_id")
  project   Project? @relation("InspectionProject", fields: [projectId], references: [id], onDelete: SetNull)

  workOrderId String?    @map("work_order_id")
  workOrder   WorkOrder? @relation("InspectionWorkOrder", fields: [workOrderId], references: [id], onDelete: SetNull)

  taskId String?       @map("task_id")
  task   AssemblyTask? @relation("InspectionTask", fields: [taskId], references: [id], onDelete: SetNull)

  /// IQC 可选关联到货记录（供「到货 → 检验」追溯）。
  arrivalId String?  @map("arrival_id")
  arrival   Arrival? @relation("InspectionArrival", fields: [arrivalId], references: [id], onDelete: SetNull)

  materialCode String? @map("material_code")
  /// 批次/序列号（§8.7 追溯对象）。FQC 一期也用它记设备号。
  batchNo      String? @map("batch_no")
  /// 供应商名快照（IQC 追溯）。ERP 供应商主数据接入后可改外键。
  supplierName String? @map("supplier_name")

  /// 检验对象说明，如「气动阀门 XX 型来料检验」。
  title String

  /// 检验员（默认创建人，可指定他人）。
  inspectorId String? @map("inspector_id")
  inspector   User?   @relation("InspectionInspector", fields: [inspectorId], references: [id], onDelete: SetNull)

  judgedById String?   @map("judged_by_id")
  judgedBy   User?     @relation("InspectionJudge", fields: [judgedById], references: [id], onDelete: SetNull)
  judgedAt   DateTime? @map("judged_at")

  remark String?

  items  InspectionItem[]
  issues QualityIssue[]   @relation("IssueInspection")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type, status])
  @@index([projectId, status])
  @@index([workOrderId])
  @@index([materialCode])
  @@map("qc_inspection")
}

/// 检验项明细行。判定后随单锁定；passed=false 的行是问题单描述的自动来源。
model InspectionItem {
  id           String     @id @default(cuid())
  inspectionId String     @map("inspection_id")
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  /// 单内行号，展示排序用。
  seq Int

  /// 检验项目，如「外观」「尺寸 φ50±0.02」。
  name String
  /// 标准要求。
  standard String?
  /// 实测值/实况记录。
  actual String?
  /// 单项判定；null=未判定。
  passed Boolean?
  remark String?

  @@index([inspectionId])
  @@map("qc_inspection_item")
}

/// 质量问题单（M8，§9.7 检验到整改闭环 + 8D 结构化字段）。编号 QI-YYYYMMDD-XXX。
/// 流转：OPEN →（分派）HANDLING →（提交整改）RECHECKING →（复检通过）CLOSED，
/// 复检不通过退回 HANDLING；未关闭前可 VOIDED（误报，区别于正常关闭）。
/// 动作规则唯一依据 shared ISSUE_ACTION_RULES（前后端同表）。
/// 区别于 M7 prod_exception：那是装配现场执行异常，这是检验驱动的正式质量闭环。
model QualityIssue {
  id   String @id @default(cuid())
  code String @unique

  /// IssueSource：INSPECTION 检验不合格自动生成 / MANUAL 手动发起。
  source String @default("MANUAL")

  inspectionId String?     @map("inspection_id")
  inspection   Inspection? @relation("IssueInspection", fields: [inspectionId], references: [id], onDelete: SetNull)

  /// QualityIssueStatus。
  status String @default("OPEN")

  /// IssueSeverity：LOW/MEDIUM/HIGH/CRITICAL。独立于项目风险等级。
  severity String @default("MEDIUM")

  projectId String?  @map("project_id")
  project   Project? @relation("QualityIssueProject", fields: [projectId], references: [id], onDelete: SetNull)

  workOrderId String?    @map("work_order_id")
  workOrder   WorkOrder? @relation("QualityIssueWorkOrder", fields: [workOrderId], references: [id], onDelete: SetNull)

  taskId String?       @map("task_id")
  task   AssemblyTask? @relation("QualityIssueTask", fields: [taskId], references: [id], onDelete: SetNull)

  materialCode String? @map("material_code")
  batchNo      String? @map("batch_no")
  supplierName String? @map("supplier_name")

  title       String
  description String?

  // ---- 8D 结构化字段：主表存最新值，每轮流转历史见动作日志 ----

  /// D3 遏制措施（临时围堵，防止不良流出）。
  containmentAction String? @map("containment_action")
  /// D4 根因分析。
  rootCause String? @map("root_cause")
  /// D5/D6 纠正措施及实施。
  correctiveAction String? @map("corrective_action")
  /// D7 预防措施（防再发，横向展开）。
  preventiveAction String? @map("preventive_action")
  /// DispositionType：不合格品处置（返工/返修/让步接收/退货/报废）。
  disposition String?

  reporterId String? @map("reporter_id")
  reporter   User?   @relation("QualityIssueReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  /// 责任人。分派后进入 HANDLING；提交整改仅限本人（或有 quality:issue:write 者代提）。
  handlerId String? @map("handler_id")
  handler   User?   @relation("QualityIssueHandler", fields: [handlerId], references: [id], onDelete: SetNull)

  closedById String?   @map("closed_by_id")
  closedBy   User?     @relation("QualityIssueCloser", fields: [closedById], references: [id], onDelete: SetNull)
  closedAt   DateTime? @map("closed_at")

  actions QualityIssueAction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, severity])
  @@index([projectId, status])
  @@index([handlerId, status])
  @@index([reporterId])
  @@index([inspectionId])
  @@map("qc_issue")
}

/// 问题单动作日志。只增不改不删——每轮分派/整改/复检/退回都是独立记录，
/// 8D 多轮整改历史由此完整可查（区别于 M7 异常单的文本前缀追加）。
model QualityIssueAction {
  id      String       @id @default(cuid())
  issueId String       @map("issue_id")
  issue   QualityIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  /// QualityIssueActionType：CREATE/ASSIGN/SUBMIT/RECHECK_PASS/RECHECK_FAIL/VOID。
  type String

  note String?

  operatorId String? @map("operator_id")
  operator   User?   @relation("QualityIssueOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([issueId, createdAt])
  @@map("qc_issue_action")
}
