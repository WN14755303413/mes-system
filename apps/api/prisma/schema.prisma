// MES 系统数据模型
// schema 由 DATABASE_URL 中的 ?schema=mes 指定，与 Supabase 自身的 auth/storage 表隔离。
//
// 本文件当前只含【系统域】。业务域（项目、BOM、工单、质量…）随各里程碑增量添加。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Transaction Pooler，运行时用
  directUrl = env("DIRECT_URL") // 直连，migrate 用（迁移不能走 pooler）
}

// ============================================================
//  组织与账号
// ============================================================

/// 部门。自引用树，`path` 存祖先链（如 /root/rd/mech/），用于 DEPT_AND_BELOW 数据权限的前缀匹配。
model Dept {
  id       String  @id @default(cuid())
  name     String
  code     String  @unique
  parentId String? @map("parent_id")
  path     String  @default("/")
  sort     Int     @default(0)
  enabled  Boolean @default(true)

  parent   Dept?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Dept[] @relation("DeptTree")
  users    User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([path])
  @@map("sys_dept")
}

model User {
  id          String @id @default(cuid())
  username    String @unique
  displayName String @map("display_name")

  /// Argon2id 哈希。系统中任何位置都不保存明文密码，本字段无法反推出原密码。
  passwordHash String @map("password_hash")

  email  String? @unique
  phone  String?
  status String  @default("ACTIVE") // UserStatus

  /// 为 true 时，除「修改密码」外的所有接口返回 403 PASSWORD_CHANGE_REQUIRED。
  /// 初始管理员 seed 后即为 true，强制首次登录改密。
  mustChangePassword Boolean @default(false) @map("must_change_password")

  /// 密码最后修改时间，用于「密码过期」策略与 token 失效判定。
  passwordChangedAt DateTime @default(now()) @map("password_changed_at")

  /// 账号锁定截止时间。连续登录失败达阈值后设置。
  lockedUntil DateTime? @map("locked_until")

  /// 连续失败次数，登录成功后清零。
  failedLoginCount Int @default(0) @map("failed_login_count")

  lastLoginAt DateTime? @map("last_login_at")
  lastLoginIp String?   @map("last_login_ip")

  /// 钉钉集成预留（建设方案 §11.1）。组织同步后，离职人员自动置为 DISABLED。
  dingtalkUserId String? @unique @map("dingtalk_userid")

  deptId String? @map("dept_id")
  dept   Dept?   @relation(fields: [deptId], references: [id], onDelete: SetNull)

  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  // 项目域反向关系（M4）
  managedProjects Project[]       @relation("ProjectManager")
  ownedTasks      ProjectTask[]   @relation("TaskOwner")
  ownedRisks      ProjectRisk[]   @relation("RiskOwner")
  ownedIssues     ProjectIssue[]  @relation("IssueOwner")
  projectMembers  ProjectMember[] @relation("ProjectMembership")

  // BOM 与图纸域反向关系（M5）
  createdBoms      Bom[]     @relation("BomCreator")
  releasedBoms     Bom[]     @relation("BomReleaser")
  uploadedDrawings Drawing[] @relation("DrawingUploader")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deptId])
  @@index([status])
  @@map("sys_user")
}

// ============================================================
//  RBAC
// ============================================================

model Role {
  id        String  @id @default(cuid())
  code      String  @unique // BuiltinRole 或自定义
  name      String
  remark    String?
  /// 该角色的数据可见范围（DataScope）。用户有多角色时取最宽松的一个。
  dataScope String  @default("SELF_ONLY") @map("data_scope")
  /// 内置角色不可删除
  builtin   Boolean @default(false)
  enabled   Boolean @default(true)

  users       UserRole[]
  permissions RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sys_role")
}

model Permission {
  id     String           @id @default(cuid())
  /// 形如 `project:create`，与 packages/shared/src/permissions.ts 保持一致
  code   String           @unique
  name   String
  module String
  roles  RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([module])
  @@map("sys_permission")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("sys_user_role")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("sys_role_permission")
}

// ============================================================
//  会话与登录防护
// ============================================================

/// Refresh token 只存哈希值。即使数据库泄露，也无法还原出可用的 token。
/// 采用轮换（rotation）策略：每次刷新签发新 token 并作废旧的。
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  /// 同一登录会话的所有 token 共享一个 family id。
  /// 检测到已撤销 token 被复用 → 判定为窃取 → 吊销整个 family。
  familyId  String    @map("family_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("sys_refresh_token")
}

/// 忘记密码申请。
///
/// 本系统没有邮件服务，也刻意不做「邮件重置链接」——内部系统的账号绑定的是工号而非邮箱，
/// 且邮件链接会新增一条可被钓鱼利用的攻击路径。改为人工核实：员工提交申请，
/// 系统管理员在后台核对姓名/手机号后重置密码并下发临时密码（mustChangePassword=true）。
///
/// 刻意不存 userId：申请提交时不校验账号是否存在（防用户名枚举），
/// 因此这里只保存用户填写的原始信息，由管理员在处理时人工匹配。
model PasswordResetRequest {
  id          String  @id @default(cuid())
  username    String
  displayName String  @map("display_name")
  phone       String
  reason      String?

  /// PENDING / APPROVED / REJECTED
  status String @default("PENDING")

  ip        String?
  userAgent String? @map("user_agent")

  /// 处理人（管理员）的用户 id 与处理备注
  handledBy  String?   @map("handled_by")
  handledAt  DateTime? @map("handled_at")
  handleNote String?   @map("handle_note")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@index([username])
  @@map("sys_password_reset_request")
}

/// 登录尝试记录。用于 IP 维度与账号维度的双重限流。
model LoginAttempt {
  id        String  @id @default(cuid())
  username  String
  ip        String
  success   Boolean
  reason    String?
  userAgent String? @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([username, createdAt])
  @@index([ip, createdAt])
  @@map("sys_login_attempt")
}

// ============================================================
//  审计与集成日志
// ============================================================

/// 操作审计（建设方案 §13）。图纸/BOM 的下载与预览单独记录。
model AuditLog {
  id         String  @id @default(cuid())
  userId     String? @map("user_id")
  username   String? // 冗余保存，用户删除后仍可追溯
  action     String // 如 project.create / drawing.download
  targetType String? @map("target_type")
  targetId   String? @map("target_id")
  /// 变更前后的 diff，仅记录发生变化的字段
  changes    Json?
  ip         String?
  userAgent  String? @map("user_agent")
  success    Boolean @default(true)
  errorMsg   String? @map("error_msg")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("sys_audit_log")
}

/// 接口日志（建设方案 §11.3）。失败的记录构成「异常池」，支持重试与人工补偿。
model IntegrationLog {
  id              String    @id @default(cuid())
  interfaceName   String    @map("interface_name")
  sourceSystem    String    @map("source_system") // ERP / DINGTALK / ANT / MES
  targetSystem    String    @map("target_system")
  requestSummary  Json?     @map("request_summary")
  responseSummary Json?     @map("response_summary")
  success         Boolean
  errorMsg        String?   @map("error_msg")
  retryCount      Int       @default(0) @map("retry_count")
  /// 待人工补偿的记录标记为 true
  needsAttention  Boolean   @default(false) @map("needs_attention")
  resolvedAt      DateTime? @map("resolved_at")
  triggeredBy     String?   @map("triggered_by") // 操作人 id 或 "SCHEDULER"

  createdAt DateTime @default(now()) @map("created_at")

  @@index([interfaceName, createdAt])
  @@index([success, needsAttention])
  @@map("sys_integration_log")
}

// ============================================================
//  编号序列（建设方案 §10.2）
// ============================================================

/// 单据流水号。用唯一约束 + 原子自增保证并发下不重号。
/// scope 形如 "PJ-2026-ABC" 或 "QC-20260709"
model CodeSequence {
  id      String @id @default(cuid())
  scope   String @unique
  current Int    @default(0)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sys_code_sequence")
}

// ============================================================
//  项目域（M4）
//
//  项目是整个 MES 的主线对象，后续里程碑的 BOM、齐套、工单、质量、
//  调试都挂到 project 上。客户/合同/物料属于 ERP 同步的主数据（后续里程碑
//  才建表），本阶段项目上先以文本字段保存客户名与合同号快照，待主数据域
//  就绪后再补外键关联。
// ============================================================

/// 项目台账。编号形如 PJ-2026-ABC-001，由 CodeGeneratorService 生成。
/// status 走通用状态机（RecordStatus）：草稿→已发布→执行中→…→已关闭。
model Project {
  id   String @id @default(cuid())
  code String @unique // PJ-2026-ABC-001
  name String

  /// 客户名快照。ERP 客户主数据接入后改为 customerId 外键。
  customerName String? @map("customer_name")
  /// 合同/销售订单号快照。同上，ERP 合同域就绪后关联。
  contractNo   String? @map("contract_no")

  /// 项目类型：单片湿法 / 槽式 / 电镀化镀 / 定制 等，一期自由文本。
  projectType String? @map("project_type")

  /// 通用状态机状态（RecordStatus）。默认草稿。
  status String @default("DRAFT")

  /// 风险等级：LOW / MEDIUM / HIGH / CRITICAL。由项目风险汇总或人工设定。
  riskLevel String @default("LOW") @map("risk_level")

  /// 设备数量。一个项目可对应一台或多台设备（建设方案 §4.1）。
  equipmentCount Int @default(1) @map("equipment_count")

  /// 项目经理（sys_user）。离职置空而非级联删项目。
  managerId String? @map("manager_id")
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  planStartAt DateTime? @map("plan_start_at")
  planEndAt   DateTime? @map("plan_end_at") // 计划交期
  actualEndAt DateTime? @map("actual_end_at") // 实际交期

  description String?

  milestones ProjectMilestone[]
  tasks      ProjectTask[]
  risks      ProjectRisk[]
  issues     ProjectIssue[]
  members    ProjectMember[]
  boms       Bom[]
  drawings   Drawing[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([status])
  @@index([managerId])
  @@map("project")
}

/// 项目里程碑（关键节点）。用于台账详情的时间轴与延期判定。
model ProjectMilestone {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name       String
  planDate   DateTime? @map("plan_date")
  /// 实际达成日期；非空即视为已完成。
  actualDate DateTime? @map("actual_date")
  sort       Int       @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("project_milestone")
}

/// WBS 任务。自引用树，是甘特图的数据源。
/// path 存祖先链（如 /rootTaskId/parentId/），与 Dept 同构，便于取整棵子树。
model ProjectTask {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentId String?       @map("parent_id")
  parent   ProjectTask?  @relation("TaskTree", fields: [parentId], references: [id], onDelete: Cascade)
  children ProjectTask[] @relation("TaskTree")
  path     String        @default("/")

  name    String
  /// 任务负责人（sys_user）。
  ownerId String? @map("owner_id")
  owner   User?   @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  planStartAt DateTime? @map("plan_start_at")
  planEndAt   DateTime? @map("plan_end_at")

  /// 完成百分比 0-100，甘特图进度条用。
  progress Int    @default(0)
  /// 任务状态（RecordStatus 子集，一期用 DRAFT/IN_PROGRESS/COMPLETED）。
  status   String @default("DRAFT")

  sort Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([parentId])
  @@index([path])
  @@map("project_task")
}

/// 项目风险登记（建设方案 §8.1）。
model ProjectRisk {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title      String
  /// 风险等级：LOW / MEDIUM / HIGH / CRITICAL。
  level      String  @default("MEDIUM")
  /// 应对措施。
  mitigation String?
  /// OPEN / CLOSED。关闭即视为已消除或已转化为问题。
  status     String  @default("OPEN")

  ownerId String? @map("owner_id")
  owner   User?   @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("project_risk")
}

/// 项目问题闭环（建设方案 §8.1）。区别于质量问题单（M7），这是项目层面的协调问题。
model ProjectIssue {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String?
  /// OPEN / IN_PROGRESS / RESOLVED / CLOSED。
  status      String  @default("OPEN")
  /// 优先级：LOW / MEDIUM / HIGH。
  priority    String  @default("MEDIUM")

  ownerId String? @map("owner_id")
  owner   User?   @relation("IssueOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  dueDate    DateTime? @map("due_date")
  resolvedAt DateTime? @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([status])
  @@map("project_issue")
}

/// 项目成员及其项目内角色。用于 OWNED_PROJECT 数据范围判定与协同人展示。
model ProjectMember {
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation("ProjectMembership", fields: [userId], references: [id], onDelete: Cascade)

  /// 项目内角色描述（如 机械设计 / 电气调试），自由文本，与全局 RBAC 角色无关。
  roleInProject String? @map("role_in_project")

  createdAt DateTime @default(now()) @map("created_at")

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_member")
}

// ============================================================
//  BOM 与图纸域（M5）
//
//  BOM 一行一个版本，走独立的 BomStatus 状态机（草稿→已发布→冻结/变更中→作废），
//  与通用 RecordStatus 分离——BOM 有「冻结」语义而无执行过程语义。
//  ECO 采用轻量版本链：新版本从 sourceBomId 派生并记录变更原因，
//  新版发布时旧版自动作废，防止现场误用旧版（业务方案 §8.2）。
// ============================================================

/// 项目 BOM 版本。version 形如 V1.0（编码规则 §10.2），同项目内唯一。
model Bom {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  version String
  /// BomStatus。现场（无 bom:write）只能看到 RELEASED / FROZEN。
  status  String  @default("DRAFT")
  remark  String?

  /// ECO 变更原因。从旧版本派生时必填（业务方案 §8.2「变更必须记录原因」）。
  changeReason String? @map("change_reason")
  /// 派生自哪个版本。初始版本为 null。删除旧版不级联新版，置空保历史。
  sourceBomId  String? @map("source_bom_id")
  source       Bom?    @relation("BomEcoChain", fields: [sourceBomId], references: [id], onDelete: SetNull)
  derived      Bom[]   @relation("BomEcoChain")

  releasedAt   DateTime? @map("released_at")
  releasedById String?   @map("released_by_id")
  releasedBy   User?     @relation("BomReleaser", fields: [releasedById], references: [id], onDelete: SetNull)

  createdById String? @map("created_by_id")
  createdBy   User?   @relation("BomCreator", fields: [createdById], references: [id], onDelete: SetNull)

  items BomItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, version])
  @@index([projectId, status])
  @@map("bom")
}

/// BOM 明细行。仅草稿状态可编辑；发布后随版本一起只读。
model BomItem {
  id    String @id @default(cuid())
  bomId String @map("bom_id")
  bom   Bom    @relation(fields: [bomId], references: [id], onDelete: Cascade)

  /// 行号，展示排序用。批量导入时自动续排，不加唯一约束以免重排受阻。
  seq          Int
  materialCode String @map("material_code")
  materialName String @map("material_name")
  spec         String?
  unit         String @default("件")
  /// 需求数量。Decimal 避免 0.1+0.2 类浮点误差进入齐套计算（M6 消费本字段）。
  quantity     Decimal @default(1) @db.Decimal(12, 3)
  /// 标准件 / 非标件（业务方案 §8.2）。
  isStandard   Boolean @default(true) @map("is_standard")
  remark       String?

  /// 关联图纸（可选）。图纸删除不连带删明细。
  drawingId String?  @map("drawing_id")
  drawing   Drawing? @relation(fields: [drawingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([bomId])
  @@map("bom_item")
}

/// 图纸。版本号沿用设计端（业务方案 §10.2），MES 记录状态与有效性。
/// 文件本体在对象存储（storageKey），下载/预览必须经后端鉴权并留审计。
model Drawing {
  id        String  @id @default(cuid())
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 图号。同项目同图号上传新版本时，旧版自动置为 VOIDED。
  code    String
  name    String
  version String
  /// DrawingStatus：ACTIVE 有效 / VOIDED 已作废。现场（无 drawing:write）只见 ACTIVE。
  status  String @default("ACTIVE")

  /// 对象存储 key，驱动无关：local 驱动是根目录内相对路径，supabase 驱动是 bucket 内路径。
  storageKey String @map("storage_key")
  fileName   String @map("file_name")
  fileSize   Int    @map("file_size")
  mimeType   String @map("mime_type")

  uploadedById String? @map("uploaded_by_id")
  uploadedBy   User?   @relation("DrawingUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  voidedAt DateTime? @map("voided_at")
  remark   String?

  bomItems BomItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([projectId, code, version])
  @@index([projectId, status])
  @@map("drawing")
}
