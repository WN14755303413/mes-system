# ============================================================
#  MES 系统环境变量模板
#  用法：cp .env.example .env  然后填入真实值
#  ⚠ .env 已被 .gitignore 忽略，绝不要提交，也不要贴到聊天/工单里
# ============================================================

# ---------- 运行环境 ----------
NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
# 前端地址，用于 CORS 白名单
WEB_ORIGIN=http://localhost:5173
# 反代信任网段（Express trust proxy），决定审计/限流如何从 X-Forwarded-For 解析真实客户端 IP。
# 默认 loopback,172.16.0.0/12 已覆盖 docker 网桥 + 宿主机 nginx 的常见链路；
# 仅当 compose 网络落在其他网段（如 192.168.x）时才需覆盖，注意不要把客户端所在网段加进来
# TRUST_PROXY=loopback,172.16.0.0/12

# ---------- Supabase / PostgreSQL ----------
# 在 Supabase 控制台 → Project Settings → Database → Connection string 获取
#
# DATABASE_URL 用 Transaction Pooler (端口 6543)，供应用运行时使用
#   末尾必须带 ?schema=mes&pgbouncer=true
DATABASE_URL="postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?schema=mes&pgbouncer=true&connection_limit=1"
#
# DIRECT_URL 用直连 (端口 5432)，供 prisma migrate 使用（迁移不能走 pooler）
DIRECT_URL="postgresql://postgres.xxxxxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres?schema=mes"

# ---------- Supabase Storage ----------
# Project Settings → API
SUPABASE_URL="https://xxxxxxxx.supabase.co"
# ⚠ service_role key 拥有完全权限，只能存在于后端，永远不要下发给前端
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET_DRAWINGS=mes-drawings
SUPABASE_BUCKET_ATTACHMENTS=mes-attachments

# ---------- 文件存储（M5） ----------
# local：写 STORAGE_LOCAL_DIR 本地磁盘（开发默认，零外部依赖）
# supabase：走上方 Supabase Storage（生产推荐，需先在控制台创建 private bucket）
STORAGE_DRIVER=local
# local 驱动的落盘根目录，相对 API 进程工作目录（apps/api）
STORAGE_LOCAL_DIR=./storage
# 单文件上传上限（MB）
MAX_UPLOAD_MB=50

# ---------- 认证 ----------
# 生成方式：openssl rand -base64 48
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# 生产环境务必设为 true（要求 HTTPS）
COOKIE_SECURE=false

# ---------- 初始管理员（仅 seed 时读取一次） ----------
# 执行 npm run db:seed 后建议从 .env 中删除此行
BOOTSTRAP_ADMIN_USERNAME=FAE@ADMIN
BOOTSTRAP_ADMIN_PASSWORD=""

# ---------- 登录防护 ----------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ---------- 系统集成（M11，一期 mock 预留） ----------
# 适配器实现：一期只有 mock（不读写真实外部系统）；二期对接后新增取值
ERP_ADAPTER=mock
DINGTALK_ADAPTER=mock
# 以下凭据 mock 模式不使用，仅在「系统集成」页展示是否已配置；二期真实适配器读取
# 用友 ERP 接口地址与令牌（以实际开放的 API/中间表方案为准）
ERP_API_BASE_URL=
ERP_API_TOKEN=
# 钉钉企业内部应用凭据（用于免登、组织同步、工作通知）
DINGTALK_AGENT_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
